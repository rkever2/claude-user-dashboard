# ============================================================
# Claude Code Usage Dashboard — Configuration
# ============================================================
# Choose a data source mode below. Copy this file to .env
# and uncomment the option that fits your setup.
#
#   Option 1: LOCAL ONLY (default)
#     Reads usage data from ~/.claude/ on this machine.
#     No API key needed. Only shows stats for this device.
#
#   Option 2: API MODE
#     Uses the Anthropic Admin API to pull usage across all
#     devices tied to your organization. Requires an admin key.
#     Local data is still used for session-level detail.
# ============================================================

# --- Data source mode ----------------------------------------
# "local"  = read only from ~/.claude/ on this machine
# "api"    = fetch org-wide usage from Anthropic Admin API
#            (local data still used for session/project detail)
DATA_SOURCE_MODE=local

# --- Local data directory ------------------------------------
# Path to your ~/.claude directory. Most users don't need to
# change this. Mounted read-only inside the container.
CLAUDE_DATA_DIR=~/.claude

# --- Anthropic Admin API (required for api mode) -------------
# Get your key at: https://console.anthropic.com/settings/admin-keys
# Requires the "org admin" role on your Anthropic account.
# ANTHROPIC_ADMIN_API_KEY=sk-ant-admin-...

# --- Dashboard port ------------------------------------------
PORT=3080
