# ============================================================
# Claude Code Usage Dashboard — Configuration
# ============================================================
# Copy this file to .env and configure as needed.
#
# By default, all data comes from local ~/.claude/ files.
# If you set ANTHROPIC_ADMIN_API_KEY, overview/activity/models/costs
# will pull from the Anthropic Admin API (org-wide, all devices).
# Sessions, projects, and insights always use local data.
# ============================================================

# --- Local data directory ------------------------------------
# Path to your ~/.claude directory. Most users don't need to
# change this. Mounted read-only inside the container.
CLAUDE_DATA_DIR=~/.claude

# --- Anthropic Admin API (optional) -------------------------
# When set, token/cost/model data comes from the API instead of local files.
# Get your key at: https://console.anthropic.com/settings/admin-keys
# Requires the "org admin" role on your Anthropic account.
# ANTHROPIC_ADMIN_API_KEY=sk-ant-admin-...

# --- Dashboard port ------------------------------------------
PORT=3080
